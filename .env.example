# SyncStream Backend Environment Variables Configuration Template

# 1. Port Number (Render sets this dynamically, defaults to 8080)
PORT=8080

# 2. Database Connection URL
# SQLite (default for development): sqlite:///./syncstream.db
# PostgreSQL (production): postgresql://username:password@hostname:5432/database
DATABASE_URL=sqlite:///./syncstream.db

# 3. Allowed CORS Origins (comma-separated list of your deployment frontend URLs)
# E.g., http://localhost:5173,https://yourfrontend.vercel.app,https://yourfrontend.netlify.app
FRONTEND_URL=http://localhost:5173

# 4. JWT Verification Secret (Must be a secure random 256-bit string in production)
JWT_SECRET=SyncStreamSecretKeyMustBeAtLeast256BitsLongForHMACSHA256AlgorithmSyncStreamSecretKeyMustBeAtLeast256BitsLongForHMACSHA256Algorithm

# 5. Google Drive API Key (Optional, used for client-side drive integration integrations)
GOOGLE_DRIVE_API_KEY=

# 6. Cloud storage configurations (Supabase Storage is supported out-of-the-box)
# If provided, uploads will be saved directly to the cloud. If omitted, falls back to local uploads/ directory.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=videos
