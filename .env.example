# Render automatically provides PORT.
# You do not need to add PORT in the Render dashboard.
PORT=10000

# Database
# For testing only (recommended: PostgreSQL on Render for production)
DATABASE_URL=sqlite:///./syncstream.db

# Frontend URL (replace with your actual Vercel URL)
FRONTEND_URL=https://video-sharing-frontend-nvss.vercel.app

# JWT Secret (replace with your own secure random value)
JWT_SECRET=SyncStreamSuperSecureJWTSecret_ReplaceThisWithYourOwnLongRandomSecret_2026

# Google Drive API Key (leave blank if not used)
GOOGLE_DRIVE_API_KEY=

# Supabase Storage (leave blank if not using Supabase)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=videos
